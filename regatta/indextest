<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>BUCS Regatta 2026 — Live Leaderboard</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">

<style>
:root {
  --primary: #97D5EB;
  --primary-dark: #5bb8d4;
  --primary-deeper: #2e8bab;
  --primary-pale: #d0eef7;
  --primary-ghost: #e8f6fb;
  --gold: #d4a017;
  --gold-bg: #fdf6e3;
  --silver: #8a9baa;
  --silver-bg: #f0f3f6;
  --bronze: #b87333;
  --bronze-bg: #faf0e6;
  --white: #ffffff;
  --bg: #f8fcfd;
  --text: #2c3e4a;
  --text-dim: #7a909e;
  --card-bg: #ffffff;
  --card-border: rgba(151, 213, 235, 0.35);
  --row-alt: rgba(151, 213, 235, 0.08);
  --row-hover: rgba(151, 213, 235, 0.15);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'DM Sans', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 0%, rgba(151,213,235,0.12) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 100%, rgba(151,213,235,0.08) 0%, transparent 50%),
    linear-gradient(180deg, #f2fafe 0%, #f8fcfd 40%, #ffffff 100%);
  z-index: -1;
}

/* HOME BUTTON */
.home-btn {
  position: fixed;
  top: 1rem;
  left: 1rem;
  width: 34px;
  height: 34px;
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(151,213,235,0.35);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  transition: all 0.2s ease;
  z-index: 1000;
}
.home-btn:hover {
  background: rgba(255,255,255,0.9);
}
.home-btn svg {
  width: 15px;
  height: 15px;
  stroke: #2e8bab;
  stroke-width: 2;
  fill: none;
}

/* HEADER */
.header {
  text-align: center;
  padding: 2rem 1rem 1rem;
  position: relative;
}
.header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--card-border), transparent);
}

.event-badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--primary-deeper);
  background: var(--primary-ghost);
  border: 1px solid var(--card-border);
  padding: 0.3rem 0.9rem;
  border-radius: 100px;
  margin-bottom: 0.6rem;
}

.header h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.6rem, 5vw, 2.4rem);
  font-weight: 400;
}

.header h1 span {
  color: var(--primary-deeper);
}

.updated {
  font-size: 0.72rem;
  color: var(--text-dim);
  margin-top: 0.5rem;
}

/* TABS */
.tabs {
  display: flex;
  padding: 1rem 0.75rem 0;
  overflow-x: auto;
}
.tabs::-webkit-scrollbar { display: none; }

.tab {
  padding: 0.55rem 0.85rem;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-dim);
  border: none;
  background: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
}
.tab.active {
  color: var(--primary-deeper);
  border-bottom-color: var(--primary-dark);
}

/* BOARD */
.board-wrap {
  padding: 0.75rem;
  max-width: 520px;
  margin: 0 auto;
}

.board {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 14px;
  overflow: hidden;
}

/* ROWS */
.row, .top3-row {
  display: grid;
  grid-template-columns: 40px 1fr auto;
  padding: 0.6rem 1rem;
}

.top3-row.first { background: var(--gold-bg); }
.top3-row.second { background: var(--silver-bg); }
.top3-row.third { background: var(--bronze-bg); }

.row:nth-child(even) { background: var(--row-alt); }

.row-rank { font-weight: 700; }
.row-club { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-pts { font-weight: 700; text-align: right; }

/* FOOTER */
.footer {
  text-align: center;
  padding: 1.5rem 1rem 2.5rem;
  font-size: 0.65rem;
  color: var(--text-dim);
}
</style>
</head>

<body>

<!-- HOME BUTTON -->
<a href="https://www.meggetland.com" class="home-btn" aria-label="Home">
  <svg viewBox="0 0 24 24">
    <path d="M3 10.5L12 3l9 7.5"></path>
    <path d="M5 10v10h14V10"></path>
  </svg>
</a>

<div class="header">
  <div class="event-badge">BUCS Regatta 2026</div>
  <h1>BUCS Regatta <span>Points Tracker</span></h1>
  <div class="updated" id="updatedTime"></div>
</div>

<div class="tabs">
  <button class="tab active" data-tab="overall_vl">Overall</button>
  <button class="tab" data-tab="mens_vl">Men's VL</button>
  <button class="tab" data-tab="womens_vl">Women's VL</button>
</div>

<div class="board-wrap">
  <div class="board" id="board"></div>
</div>

<div class="footer">
  Updated live from Google Sheets
</div>

<script>
const SHEET_CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSa6hutAyunAB6--x0cx_ShY-KXBJsR8v42BXrLlG4JYX3tgV9NXHEgH96FWt6nE0mg8A_uNnorTlr3/pub?gid=474748749&single=true&output=csv';

async function fetchData() {
  const resp = await fetch(SHEET_CSV_URL);
  const csv = await resp.text();
  const rows = csv.split('\\n').slice(1);

  const data = rows.map(r => {
    const c = r.split(',');
    return { club: c[0], pts: Number(c[1]) || 0 };
  }).sort((a,b) => b.pts - a.pts);

  render(data);
}

function render(data) {
  const board = document.getElementById('board');
  board.innerHTML = data.map((r,i) => `
    <div class="row">
      <div class="row-rank">${i+1}</div>
      <div class="row-club">${r.club}</div>
      <div class="row-pts">${r.pts}</div>
    </div>
  `).join('');
}

fetchData();
</script>

</body>
</html>
